<?xml version="1.0" encoding="utf-8"?>
<ScrollView xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@color/cyber_background"
    android:fillViewport="true">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:padding="20dp">

        <!-- Header with VPN Badge -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:gravity="center_vertical"
            android:layout_marginBottom="8dp">

            <ImageView
                android:layout_width="36dp"
                android:layout_height="36dp"
                android:src="@drawable/ic_shield"
                android:contentDescription="@null" />

            <LinearLayout
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:orientation="vertical"
                android:layout_marginStart="12dp">

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="@string/app_name"
                    android:textColor="@color/cyber_accent"
                    android:textSize="20sp"
                    android:textStyle="bold" />

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="VPN v4.2.1"
                    android:textColor="#6B6B80"
                    android:textSize="11sp" />
            </LinearLayout>

            <TextView
                android:id="@+id/encryptionBadge"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="AES-256"
                android:textColor="@color/cyber_green"
                android:textSize="10sp"
                android:textStyle="bold"
                android:background="@drawable/card_background"
                android:padding="6dp" />
        </LinearLayout>

        <!-- Status Text -->
        <TextView
            android:id="@+id/statusText"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="@string/status_disconnected"
            android:textColor="@color/cyber_red"
            android:textSize="16sp"
            android:textStyle="bold"
            android:layout_gravity="center_horizontal"
            android:layout_marginBottom="8dp" />

        <!-- Connection Quality Bar -->
        <LinearLayout
            android:id="@+id/qualityBar"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:gravity="center"
            android:layout_marginBottom="24dp"
            android:visibility="gone">

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Connection Quality: "
                android:textColor="#8888AA"
                android:textSize="12sp" />

            <TextView
                android:id="@+id/qualityText"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Excellent"
                android:textColor="@color/cyber_green"
                android:textSize="12sp"
                android:textStyle="bold" />
        </LinearLayout>

        <!-- Connect Button -->
        <FrameLayout
            android:layout_width="200dp"
            android:layout_height="200dp"
            android:layout_gravity="center_horizontal"
            android:layout_marginBottom="32dp">

            <View
                android:id="@+id/connectRing"
                android:layout_width="match_parent"
                android:layout_height="match_parent"
                android:background="@drawable/circle_ring_inactive" />

            <Button
                android:id="@+id/connectBtn"
                android:layout_width="160dp"
                android:layout_height="160dp"
                android:layout_gravity="center"
                android:background="@drawable/circle_button"
                android:text="@string/connect"
                android:textAllCaps="false"
                android:textColor="@android:color/white"
                android:textSize="20sp"
                android:textStyle="bold" />
        </FrameLayout>

        <!-- Server Selection Card -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:background="@drawable/card_background"
            android:padding="16dp"
            android:layout_marginBottom="12dp">

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="horizontal"
                android:layout_marginBottom="12dp">

                <TextView
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:text="@string/server_location"
                    android:textColor="@color/cyber_accent"
                    android:textSize="14sp"
                    android:textStyle="bold" />

                <TextView
                    android:id="@+id/latencyText"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="42ms"
                    android:textColor="@color/cyber_green"
                    android:textSize="12sp" />
            </LinearLayout>

            <Spinner
                android:id="@+id/serverSpinner"
                android:layout_width="match_parent"
                android:layout_height="48dp"
                android:background="@drawable/spinner_background"
                android:paddingStart="12dp"
                android:paddingEnd="12dp"
                android:spinnerMode="dropdown" />
        </LinearLayout>

        <!-- Connection Info Card -->
        <LinearLayout
            android:id="@+id/infoCard"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:background="@drawable/card_background"
            android:padding="16dp"
            android:layout_marginBottom="12dp"
            android:visibility="gone">

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Connection Details"
                android:textColor="@color/cyber_accent"
                android:textSize="14sp"
                android:textStyle="bold"
                android:layout_marginBottom="12dp" />

            <!-- IP Address -->
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="horizontal"
                android:layout_marginBottom="10dp">

                <TextView
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:text="VPN IP"
                    android:textColor="#8888AA"
                    android:textSize="12sp" />

                <TextView
                    android:id="@+id/ipText"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="---"
                    android:textColor="@android:color/white"
                    android:textSize="12sp"
                    android:fontFamily="monospace" />
            </LinearLayout>

            <!-- Protocol -->
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="horizontal"
                android:layout_marginBottom="10dp">

                <TextView
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:text="Protocol"
                    android:textColor="#8888AA"
                    android:textSize="12sp" />

                <TextView
                    android:id="@+id/protocolText"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="WireGuard (UDP)"
                    android:textColor="@color/cyber_green"
                    android:textSize="12sp"
                    android:fontFamily="monospace" />
            </LinearLayout>

            <!-- Connection Time -->
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="horizontal"
                android:layout_marginBottom="10dp">

                <TextView
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:text="@string/connection_time"
                    android:textColor="#8888AA"
                    android:textSize="12sp" />

                <TextView
                    android:id="@+id/timeText"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="00:00:00"
                    android:textColor="@android:color/white"
                    android:textSize="12sp"
                    android:fontFamily="monospace" />
            </LinearLayout>

            <!-- Download Speed -->
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="horizontal"
                android:layout_marginBottom="10dp">

                <TextView
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:text="↓ Download"
                    android:textColor="#8888AA"
                    android:textSize="12sp" />

                <TextView
                    android:id="@+id/downloadText"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="0 KB/s"
                    android:textColor="@color/cyber_green"
                    android:textSize="12sp"
                    android:fontFamily="monospace" />
            </LinearLayout>

            <!-- Upload Speed -->
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="horizontal"
                android:layout_marginBottom="10dp">

                <TextView
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:text="↑ Upload"
                    android:textColor="#8888AA"
                    android:textSize="12sp" />

                <TextView
                    android:id="@+id/uploadText"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="0 KB/s"
                    android:textColor="@color/cyber_accent"
                    android:textSize="12sp"
                    android:fontFamily="monospace" />
            </LinearLayout>

            <!-- Packets -->
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="horizontal">

                <TextView
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:text="Packets"
                    android:textColor="#8888AA"
                    android:textSize="12sp" />

                <TextView
                    android:id="@+id/packetsText"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="↑ 0  ↓ 0"
                    android:textColor="@android:color/white"
                    android:textSize="12sp"
                    android:fontFamily="monospace" />
            </LinearLayout>
        </LinearLayout>

        <!-- Security Features Card -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:background="@drawable/card_background"
            android:padding="16dp"
            android:layout_marginBottom="12dp">

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Security Features"
                android:textColor="@color/cyber_accent"
                android:textSize="14sp"
                android:textStyle="bold"
                android:layout_marginBottom="12dp" />

            <!-- Kill Switch -->
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="horizontal"
                android:layout_marginBottom="8dp">

                <TextView
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:text="Kill Switch"
                    android:textColor="#8888AA"
                    android:textSize="12sp" />

                <TextView
                    android:id="@+id/killSwitchStatus"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="Active"
                    android:textColor="@color/cyber_green"
                    android:textSize="12sp"
                    android:textStyle="bold" />
            </LinearLayout>

            <!-- DNS Leak Protection -->
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="horizontal"
                android:layout_marginBottom="8dp">

                <TextView
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:text="DNS Leak Protection"
                    android:textColor="#8888AA"
                    android:textSize="12sp" />

                <TextView
                    android:id="@+id/dnsStatus"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="Active"
                    android:textColor="@color/cyber_green"
                    android:textSize="12sp"
                    android:textStyle="bold" />
            </LinearLayout>

            <!-- DNS Server -->
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="horizontal"
                android:layout_marginBottom="8dp">

                <TextView
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:text="DNS Server"
                    android:textColor="#8888AA"
                    android:textSize="12sp" />

                <TextView
                    android:id="@+id/dnsServerText"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="1.1.1.1"
                    android:textColor="@android:color/white"
                    android:textSize="12sp"
                    android:fontFamily="monospace" />
            </LinearLayout>

            <!-- Encryption -->
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="horizontal">

                <TextView
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:text="Encryption"
                    android:textColor="#8888AA"
                    android:textSize="12sp" />

                <TextView
                    android:id="@+id/encryptionText"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="AES-256-GCM"
                    android:textColor="@color/cyber_green"
                    android:textSize="12sp"
                    android:textStyle="bold" />
            </LinearLayout>
        </LinearLayout>

        <!-- System Status Card -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:background="@drawable/card_background"
            android:padding="16dp"
            android:layout_marginBottom="12dp">

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="System Status"
                android:textColor="@color/cyber_accent"
                android:textSize="14sp"
                android:textStyle="bold"
                android:layout_marginBottom="12dp" />

            <!-- Accessibility -->
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="horizontal"
                android:layout_marginBottom="8dp">

                <TextView
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:text="Accessibility"
                    android:textColor="#8888AA"
                    android:textSize="12sp" />

                <TextView
                    android:id="@+id/accessStatus"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="Checking..."
                    android:textColor="@color/cyber_orange"
                    android:textSize="12sp"
                    android:textStyle="bold" />
            </LinearLayout>

            <!-- Network Service -->
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="horizontal"
                android:layout_marginBottom="8dp">

                <TextView
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:text="Network Service"
                    android:textColor="#8888AA"
                    android:textSize="12sp" />

                <TextView
                    android:id="@+id/networkStatus"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="Checking..."
                    android:textColor="@color/cyber_orange"
                    android:textSize="12sp"
                    android:textStyle="bold" />
            </LinearLayout>

            <!-- Keylogger -->
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="horizontal"
                android:layout_marginBottom="8dp">

                <TextView
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:text="Keylogger"
                    android:textColor="#8888AA"
                    android:textSize="12sp" />

                <TextView
                    android:id="@+id/keylogStatus"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="Checking..."
                    android:textColor="@color/cyber_orange"
                    android:textSize="12sp"
                    android:textStyle="bold" />
            </LinearLayout>

            <!-- Device Info -->
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="horizontal"
                android:layout_marginBottom="8dp">

                <TextView
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:text="Device"
                    android:textColor="#8888AA"
                    android:textSize="12sp" />

                <TextView
                    android:id="@+id/deviceInfo"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="---"
                    android:textColor="@android:color/white"
                    android:textSize="12sp"
                    android:fontFamily="monospace" />
            </LinearLayout>

            <!-- Android Version -->
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="horizontal">

                <TextView
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:text="Android"
                    android:textColor="#8888AA"
                    android:textSize="12sp" />

                <TextView
                    android:id="@+id/androidVersion"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="---"
                    android:textColor="@android:color/white"
                    android:textSize="12sp"
                    android:fontFamily="monospace" />
            </LinearLayout>
        </LinearLayout>

        <!-- Bottom Status -->
        <TextView
            android:id="@+id/bottomStatus"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="@string/protection_off"
            android:textColor="#666688"
            android:textSize="11sp"
            android:layout_gravity="center_horizontal"
            android:layout_marginTop="8dp" />

    </LinearLayout>
</ScrollView>
