<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:orientation="vertical"
    android:padding="16dp"
    android:gravity="center">

    <TextView
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="Enterprise Support"
        android:textSize="24sp"
        android:textStyle="bold"
        android:layout_marginBottom="32dp" />

    <Button
        android:id="@+id/btn_start_support"
        android:layout_width="200dp"
        android:layout_height="wrap_content"
        android:text="Start Support Session"
        android:layout_marginBottom="16dp" />

    <Button
        android:id="@+id/btn_stop_support"
        android:layout_width="200dp"
        android:layout_height="wrap_content"
        android:text="Stop Support Session"
        android:layout_marginBottom="32dp" />

    <TextView
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="Remote Actions"
        android:textSize="18sp"
        android:textStyle="bold"
        android:layout_marginBottom="16dp" />

    <Button
        android:id="@+id/btn_highlight"
        android:layout_width="200dp"
        android:layout_height="wrap_content"
        android:text="Highlight Element"
        android:layout_marginBottom="16dp" />

    <Button
        android:id="@+id/btn_click"
        android:layout_width="200dp"
        android:layout_height="wrap_content"
        android:text="Auto-Click Element" />

</LinearLayout>